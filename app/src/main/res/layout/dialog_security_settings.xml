<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/auth_access_switch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/auth_required_for_access"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/auth_required_for_access_summary"
        android:textAppearance="?attr/textAppearanceBodySmall"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:layout_marginBottom="16dp"
        android:paddingStart="4dp"
        android:paddingEnd="4dp" />

    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/auth_password_reveal_switch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/auth_required_for_password_reveal"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/auth_required_for_password_reveal_summary"
        android:textAppearance="?attr/textAppearanceBodySmall"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:layout_marginBottom="16dp"
        android:paddingStart="4dp"
        android:paddingEnd="4dp" />

    <TextView
        android:id="@+id/auth_not_available_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/auth_not_available"
        android:textAppearance="?attr/textAppearanceBodySmall"
        android:textColor="?attr/colorError"
        android:visibility="gone"
        android:paddingStart="4dp"
        android:paddingEnd="4dp" />

</LinearLayout>
